import imageCompression from "browser-image-compression";

export async function compressImage(file) {
  const options = {
    maxSizeMB: 0.18,
    maxWidthOrHeight: 900,
    useWebWorker: true,
    initialQuality: 0.55,
  };

  try {
    const compressedFile = await imageCompression(file, options);

    return compressedFile;
  } catch (error) {
    console.error(error);
    return file;
  }
}